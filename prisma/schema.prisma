generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  netid     String?  @unique
  email     String?  @unique
  username  String?  @unique
  passwordHash String?
  createdAt DateTime @default(now())

  profile         Profile?
  completedCourses CompletedCourse[]
  plans           Plan[]
  auditLogs       AuditLog[]
}

model Profile {
  id            String  @id @default(cuid())
  userId        String  @unique
  school        String
  catalogYear   String
  majors        String[]
  minors        String[]
  gradTarget    String

  user User @relation(fields: [userId], references: [id])
}

model CompletedCourse {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  termTaken String?
  grade     String?

  user User @relation(fields: [userId], references: [id])
}

model Plan {
  id          String   @id @default(cuid())
  userId      String
  generatedAt DateTime @default(now())
  planJson    Json

  user User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  action    String
  path      String
  ip        String?
  userAgent String?
  userId    String?
  metadata  Json?

  user User? @relation(fields: [userId], references: [id])
}
